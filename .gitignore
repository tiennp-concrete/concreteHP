# ==========================================================================
# Theme: concrete-child — compiled CSS / SCSS artifacts
# ==========================================================================
src/wp-content/themes/concrete-child/assets/css/*.css
src/wp-content/themes/concrete-child/assets/css/*.css.map
src/wp-content/themes/concrete-child/assets/css/*.min.css
src/wp-content/themes/concrete-child/.sass-cache/

# SCSS build cache (gulp-sass)
.sass-cache/
coding_html/assets/scss/**/*.map

# ==========================================================================
# Plugin: concrete-blocks — build artifacts from html-to-gutenberg + webpack
# ==========================================================================
src/wp-content/plugins/concrete-blocks/node_modules/
src/wp-content/plugins/concrete-blocks/build/
src/wp-content/plugins/concrete-blocks/generated-blocks/

# ==========================================================================
# Keep .gitkeep files
# ==========================================================================
!.gitkeep
