{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "concrete/about",
  "title": "About Us",
  "category": "theme",
  "textdomain": "about",
  "version": "0.3.0",
  "description": "Two-column about section with heading, description, stats and CTA.",
  "attributes": {
    "align": {
      "type": "string",
      "default": "full"
    },
    "eyebrow": {
      "type": "string",
      "default": "ABOUT US"
    },
    "heading": {
      "type": "string",
      "default": "More Than Just"
    },
    "headingSub": {
      "type": "string",
      "default": "A Dev Company"
    },
    "description": {
      "type": "string",
      "default": "CONCRETE is a creative technology group headquartered in Tokyo. We connect talented creators across Japan and Vietnam to build excellent web systems, support startups, and empower businesses to grow through the power of technology."
    },
    "ctaText": {
      "type": "string",
      "default": "Learn more about us"
    },
    "ctaUrl": {
      "type": "string",
      "default": "#about"
    },
    "image": {
      "type": "string",
      "default": "/wp-content/themes/concrete-child/assets/images/About-Us_team.png"
    },
    "stats": {
      "type": "array",
      "default": [
        { "number": "6+", "label": "Years Experience" },
        { "number": "50+", "label": "Clients Served" },
        { "number": "100+", "label": "Projects Delivered" }
      ]
    }
  },
  "supports": {
    "html": false,
    "align": ["full"]
  },
  "editorScript": "file:./index.js",
  "render": "file:./render.php",
  "example": {}
}