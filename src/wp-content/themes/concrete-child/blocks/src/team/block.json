{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "concrete/team",
  "title": "Team",
  "category": "theme",
  "textdomain": "team",
  "version": "0.3.0",
  "description": "Team section with 2-col layout and floating decorative shapes.",
  "attributes": {
    "align": {
      "type": "string",
      "default": "full"
    },
    "eyebrow": {
      "type": "string",
      "default": "OUR TEAM"
    },
    "heading": {
      "type": "string",
      "default": "Meet our <br>professional"
    },
    "headingSub": {
      "type": "string",
      "default": "Experts"
    },
    "description": {
      "type": "string",
      "default": "CONCRETE is a creative group headquartered in Tokyo, developing systems utilizing the latest technology. Our 45+ members across Japan and Vietnam are united by one mission — building excellent digital products that make a real impact."
    },
    "ctaText": {
      "type": "string",
      "default": "Meet our team"
    },
    "heroImage": {
      "type": "string",
      "default": "/wp-content/themes/concrete-child/assets/images/slider_animation_team.png"
    },
    "shapes": {
      "type": "array",
      "default": [
        {
          "image": "/wp-content/themes/concrete-child/assets/images/team_s3.png",
          "variant": "ts-1 animation"
        },
        {
          "image": "/wp-content/themes/concrete-child/assets/images/1-team_s42.png",
          "variant": "ts-2 animation"
        },
        {
          "image": "/wp-content/themes/concrete-child/assets/images/team_s1.png",
          "variant": "ts-3 animation"
        }
      ]
    }
  },
  "supports": {
    "html": false,
    "align": [
      "full"
    ]
  },
  "editorScript": "file:./index.js",
  "render": "file:./render.php",
  "example": {}
}
