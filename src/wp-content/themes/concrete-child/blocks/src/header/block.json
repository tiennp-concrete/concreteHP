{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "concrete/header",
  "title": "Header",
  "category": "theme",
  "textdomain": "header",
  "version": "0.3.0",
  "description": "Sticky marketing header with logo + nav + CTA.",
  "attributes": {
    "align": { "type": "string", "default": "full" },
    "logoUrl": {
      "type": "string",
      "default": "/wp-content/themes/concrete-child/assets/images/logo_coc.png"
    },
    "brand": { "type": "string", "default": "Concrete" },
    "ctaText": { "type": "string", "default": "Make it Concrete" }
  },
  "supports": {
    "html": false,
    "align": ["full"]
  },
  "editorScript": "file:./index.js",
  "render": "file:./render.php",
  "viewScript": "file:./view.js",
  "example": {}
}