      "default": "love us - and you will too"
    },
    "decorImage": {
      "type": "string",
      "default": "/wp-content/themes/concrete-child/assets/images/bg_animation1.png"
    },
    "projects": {
      "type": "array",
      "default": [
        {
          "image": "/wp-content/themes/concrete-child/assets/images/project_1-630x310.jpg",
          "category": "branding",
