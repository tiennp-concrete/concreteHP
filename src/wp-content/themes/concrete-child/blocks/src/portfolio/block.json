{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "concrete/portfolio",
  "title": "Portfolio",
  "category": "theme",
  "textdomain": "portfolio",
  "version": "0.3.0",
  "description": "Portfolio grid with category filter and fully-interactive admin preview.",
  "attributes": {
    "align": {
      "type": "string",
      "default": "full"
    },
    "eyebrow": {
      "type": "string",
      "default": "OUR WORKS"
    },
    "heading": {
      "type": "string",
      "default": "Check out our work to see why our clients"
    },
    "headingSub": {
