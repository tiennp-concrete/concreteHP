{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "concrete/footer",
  "title": "Footer",
  "category": "theme",
  "textdomain": "footer",
  "version": "0.3.0",
  "description": "4-column footer with brand, link groups and newsletter form.",
  "attributes": {
    "align": {
      "type": "string",
      "default": "full"
    },
    "logoUrl": {
      "type": "string",
      "default": "/wp-content/themes/concrete-child/assets/images/logo_concrete_corp.svg"
    },
    "brand": {
      "type": "string",
      "default": "Concrete"
    },
    "tagline": {
      "type": "string",
      "default": "We help businesses maximize their online presence with a personalized approach to digital marketing."
    },
    "colCompanyHeading": {
      "type": "string",
      "default": "Company"
    },
    "colResourcesHeading": {
      "type": "string",
      "default": "Resources"
    },
    "newsletterHeading": {
      "type": "string",
      "default": "Newsletters"
    },
    "newsletterText": {
      "type": "string",
      "default": "Subscribe our newsletters to get update and more"
    },
    "phone": {
      "type": "string",
      "default": "(+84) 0123 4567 8"
    },
    "email": {
      "type": "string",
      "default": "hello@zahar.com"
    },
    "copyright": {
      "type": "string",
      "default": "Copyright © 2026 Zahar. All Rights Reserved."
    },
    "companyItems": {
      "type": "array",
      "default": [
        {
          "text": "About",
          "url": "#"
        },
        {
          "text": "Project",
          "url": "#"
        },
        {
          "text": "Services",
          "url": "#"
        },
        {
          "text": "Blog",
          "url": "#"
        },
        {
          "text": "Contact",
          "url": "#"
        }
      ]
    },
    "resourcesItems": {
      "type": "array",
      "default": [
        {
          "text": "Support",
          "url": "#"
        },
        {
          "text": "Documentation",
          "url": "#"
        },
        {
          "text": "Community",
          "url": "#"
        },
        {
          "text": "Reports",
          "url": "#"
        },
        {
          "text": "Recruitment",
          "url": "#"
        }
      ]
    }
  },
  "supports": {
    "html": false,
    "align": [
      "full"
    ]
  },
  "editorScript": "file:./index.js",
  "render": "file:./render.php",
  "example": {}
}
