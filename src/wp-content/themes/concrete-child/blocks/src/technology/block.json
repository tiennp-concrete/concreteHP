{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "concrete/technology",
  "title": "Technology",
  "category": "theme",
  "textdomain": "technology",
  "version": "0.2.0",
  "description": "Technology stack — left heading + tab nav, right 2-card panel per tab.",
  "attributes": {
    "align":      { "type": "string", "default": "full" },
    "eyebrow":    { "type": "string", "default": "TECHNOLOGY" },
    "heading":    { "type": "string", "default": "Technologies we use" },
    "headingSub": { "type": "string", "default": "to build your product" },
    "tabs": {
      "type": "array",
      "default": [
        {
          "num": "01",
          "label": "Development",
          "categories": [
            {
              "name": "Languages &amp; Frameworks",
              "icons": [
                { "src": "/wp-content/themes/concrete-child/assets/images/tech/php.svg",        "alt": "PHP" },
                { "src": "/wp-content/themes/concrete-child/assets/images/tech/laravel.svg",    "alt": "Laravel" },
                { "src": "/wp-content/themes/concrete-child/assets/images/tech/python.svg",     "alt": "Python" },
                { "src": "/wp-content/themes/concrete-child/assets/images/tech/nodejs.svg",     "alt": "Node.js" },
                { "src": "/wp-content/themes/concrete-child/assets/images/tech/javascript.svg", "alt": "JavaScript" },
                { "src": "/wp-content/themes/concrete-child/assets/images/tech/nuxt.svg",       "alt": "Nuxt 3" },
                { "src": "/wp-content/themes/concrete-child/assets/images/tech/vuejs.svg",      "alt": "Vue.js" },
                { "src": "/wp-content/themes/concrete-child/assets/images/tech/react.svg",      "alt": "React" },
                { "src": "/wp-content/themes/concrete-child/assets/images/tech/typescript.svg", "alt": "TypeScript" },
                { "src": "/wp-content/themes/concrete-child/assets/images/tech/graphql.svg",    "alt": "GraphQL" }
              ]
            },
            {
              "name": "Mobile Apps",
              "icons": [
                { "src": "/wp-content/themes/concrete-child/assets/images/tech/swift.svg",        "alt": "Swift" },
                { "src": "/wp-content/themes/concrete-child/assets/images/tech/kotlin.svg",       "alt": "Kotlin" },
                { "src": "/wp-content/themes/concrete-child/assets/images/tech/react-native.svg", "alt": "React Native" },
                { "src": "/wp-content/themes/concrete-child/assets/images/tech/line.svg",         "alt": "LINE Mini App" }
              ]
            }
          ]
        },
        {
          "num": "02",
          "label": "Infrastructure &amp; AI",
          "categories": [
            {
              "name": "Infrastructure",
              "icons": [
                { "src": "/wp-content/themes/concrete-child/assets/images/tech/aws.svg",        "alt": "AWS" },
                { "src": "/wp-content/themes/concrete-child/assets/images/tech/gcp.svg",        "alt": "GCP" },
                { "src": "/wp-content/themes/concrete-child/assets/images/tech/docker.svg",     "alt": "Docker" },
                { "src": "/wp-content/themes/concrete-child/assets/images/tech/kubernetes.svg", "alt": "Kubernetes" }
              ]
            },
            {
              "name": "AI",
              "icons": [
                { "src": "/wp-content/themes/concrete-child/assets/images/tech/chatgpt.svg",       "alt": "ChatGPT" },
                { "src": "/wp-content/themes/concrete-child/assets/images/tech/coderabbit.svg",    "alt": "CodeRabbit" },
                { "src": "/wp-content/themes/concrete-child/assets/images/tech/github-copilot.svg","alt": "GitHub Copilot" }
              ]
            }
          ]
        },
        {
          "num": "03",
          "label": "Analytics &amp; Tools",
          "categories": [
            {
              "name": "Data Analysis",
              "icons": [
                { "src": "/wp-content/themes/concrete-child/assets/images/tech/ga.svg",            "alt": "Google Analytics" },
                { "src": "/wp-content/themes/concrete-child/assets/images/tech/bigquery.svg",      "alt": "BigQuery" },
                { "src": "/wp-content/themes/concrete-child/assets/images/tech/elasticsearch.svg", "alt": "Elastic Search" },
                { "src": "/wp-content/themes/concrete-child/assets/images/tech/gtm.svg",           "alt": "Google Tag Manager" },
                { "src": "/wp-content/themes/concrete-child/assets/images/tech/sentry.svg",        "alt": "Sentry" }
              ]
            },
            {
              "name": "Management &amp; Communication",
              "icons": [
                { "src": "/wp-content/themes/concrete-child/assets/images/tech/github.svg",  "alt": "GitHub" },
                { "src": "/wp-content/themes/concrete-child/assets/images/tech/notion.svg",  "alt": "Notion" },
                { "src": "/wp-content/themes/concrete-child/assets/images/tech/backlog.svg", "alt": "Backlog" },
                { "src": "/wp-content/themes/concrete-child/assets/images/tech/slack.svg",   "alt": "Slack" },
                { "src": "/wp-content/themes/concrete-child/assets/images/tech/figma.svg",   "alt": "Figma" }
              ]
            }
          ]
        }
      ]
    }
  },
  "supports": { "html": false, "align": ["full"] },
  "editorScript": "file:./index.js",
  "render":       "file:./render.php",
  "viewScript":   "file:./view.js",
  "example": {}
}
