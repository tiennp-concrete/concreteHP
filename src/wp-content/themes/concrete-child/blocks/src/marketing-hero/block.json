{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "concrete/marketing-hero",
  "title": "Marketing Hero",
  "category": "theme",
  "textdomain": "marketing-hero",
  "version": "0.3.0",
  "description": "Hero section with split title, play video icon, and floating decorative shapes.",
  "attributes": {
    "align": {
      "type": "string",
      "default": "full"
    },
    "eyebrow": {
      "type": "string",
      "default": "DIGITAL AGENCY"
    },
    "title": {
      "type": "string",
      "default": "Let's Be Better"
    },
    "titleSub": {
      "type": "string",
      "default": "Every Day"
    },
    "subtitle": {
      "type": "string",
      "default": "We're a creative digital performance marketing agency that helps passionate organizations achieve inspiring results."
    },
    "primaryCta": {
      "type": "string",
      "default": "Get started"
    },
    "videoLabel": {
      "type": "string",
      "default": "See live demo"
    },
    "videoUrl": {
      "type": "string",
      "default": "https://www.youtube.com/watch?v=JtVd7q25FDA"
    },
    "heroImage": {
      "type": "string",
      "default": "/wp-content/themes/concrete-child/assets/images/team.png"
    },
    "shapes": {
      "type": "array",
      "default": [
        {
          "image": "/wp-content/themes/concrete-child/assets/images/shape2.png",
          "variant": "zh-s-1 zh-float-ud"
        },
        {
          "image": "/wp-content/themes/concrete-child/assets/images/shape2.png",
          "variant": "zh-s-2 zh-float-circle"
        },
        {
          "image": "/wp-content/themes/concrete-child/assets/images/shade1.png",
          "variant": "zh-s-3 zh-float-top"
        },
        {
          "image": "/wp-content/themes/concrete-child/assets/images/img_animation.png",
          "variant": "zh-s-4 zh-float-small"
        },
        {
          "image": "/wp-content/themes/concrete-child/assets/images/img_animation.png",
          "variant": "zh-s-5 zh-float-zoom"
        }
      ]
    }
  },
  "supports": {
    "html": false,
    "align": [
      "full"
    ]
  },
  "editorScript": "file:./index.js",
  "render": "file:./render.php",
  "example": {}
}
