{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "concrete/marketing-hero",
  "title": "Marketing Hero",
  "category": "theme",
  "textdomain": "marketing-hero",
  "version": "0.3.0",
  "description": "Hero section with split title, play video icon, and floating decorative shapes.",
  "attributes": {
    "align": {
      "type": "string",
      "default": "full"
    },
    "eyebrow": {
      "type": "string",
      "default": "WEB & SOFTWARE DEVELOPMENT"
    },
    "title": {
      "type": "string",
      "default": "Built to Grow"
    },
    "titleSub": {
      "type": "string",
      "default": "For Your Business"
    },
    "subtitle": {
      "type": "string",
      "default": "We deliver high-quality web systems, BPO services and software solutions — trusted by businesses across Japan, Vietnam and beyond."
    },
    "primaryCta": {
      "type": "string",
      "default": "Start a Project"
    },
    "videoLabel": {
      "type": "string",
      "default": "View Our Work"
    },
    "videoUrl": {
      "type": "string",
      "default": "https://www.youtube.com/watch?v=JtVd7q25FDA"
    },
    "heroImage": {
      "type": "string",
      "default": "/wp-content/themes/concrete-child/assets/images/team.png"
    },
    "shapes": {
      "type": "array",
      "default": [
        {
          "image": "/wp-content/themes/concrete-child/assets/images/shape2.png",
          "variant": "s-1 animation"
        },
        {
          "image": "/wp-content/themes/concrete-child/assets/images/shape2.png",
          "variant": "s-2 animation"
        },
        {
          "image": "/wp-content/themes/concrete-child/assets/images/shade1.png",
          "variant": "s-3 animation"
        },
        {
          "image": "/wp-content/themes/concrete-child/assets/images/img_animation.png",
          "variant": "s-4 animation"
        },
        {
          "image": "/wp-content/themes/concrete-child/assets/images/img_animation.png",
          "variant": "s-5 animation"
        },
        {
          "image": "/wp-content/themes/concrete-child/assets/images/img_animation.png",
          "variant": "s-6 animation"
        }
      ]
    }
  },
  "supports": {
    "html": false,
    "align": [
      "full"
    ]
  },
  "editorScript": "file:./index.js",
  "render": "file:./render.php",
  "example": {}
}
