{
  "$schema": "https://schemas.wp.org/wp/6.5/theme.json",
  "version": 2,
  "title": "Concrete HP",
  "description": "Modern corporate theme inspired by Sun* Asterisk design",
  "settings": {
    "appearanceTools": true,
    "useRootPaddingAwareAlignment": true,
    "color": {
      "defaultPalette": false,
      "palette": [
        {
          "color": "#1a1a2e",
          "name": "Primary Dark",
          "slug": "primary-dark"
        },
        {
          "color": "#0f3460",
          "name": "Primary Blue",
          "slug": "primary-blue"
        },
        {
          "color": "#e94560",
          "name": "Accent Red",
          "slug": "accent-red"
        },
        {
          "color": "#ff6b35",
          "name": "Accent Orange",
          "slug": "accent-orange"
        },
        {
          "color": "#222222",
          "name": "Text Dark",
          "slug": "text-dark"
        },
        {
          "color": "#555555",
          "name": "Text Body",
          "slug": "text-body"
        },
        {
          "color": "#f8f9fa",
          "name": "Background Light",
          "slug": "bg-light"
        },
        {
          "color": "#ffffff",
          "name": "White",
          "slug": "white"
        }
      ],
      "gradients": [
        {
          "gradient": "linear-gradient(135deg, #1a1a2e 0%, #0f3460 100%)",
          "name": "Primary Gradient",
          "slug": "primary-gradient"
        },
        {
          "gradient": "linear-gradient(135deg, #e94560, #ff6b35)",
          "name": "Accent Gradient",
          "slug": "accent-gradient"
        }
      ]
    },
    "typography": {
      "defaultFontSizes": false,
      "fontSizes": [
        { "size": "12px", "slug": "xs", "name": "Extra Small" },
        { "size": "14px", "slug": "sm", "name": "Small" },
        { "size": "16px", "slug": "md", "name": "Medium" },
        { "size": "18px", "slug": "lg", "name": "Large" },
        { "size": "24px", "slug": "xl", "name": "Extra Large" },
        { "size": "32px", "slug": "2xl", "name": "2X Large" },
        { "size": "40px", "slug": "3xl", "name": "3X Large" },
        { "size": "48px", "slug": "4xl", "name": "4X Large" },
        { "size": "56px", "slug": "5xl", "name": "5X Large" }
      ],
      "fontFamilies": [
        {
          "fontFamily": "'Roboto', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif",
          "name": "Roboto",
          "slug": "roboto"
        },
        {
          "fontFamily": "'Noto Sans', sans-serif",
          "name": "Noto Sans",
          "slug": "noto-sans"
        }
      ]
    },
    "spacing": {
      "defaultSpacingSizes": false,
      "spacingSizes": [
        { "size": "8px", "slug": "xs", "name": "Extra Small" },
        { "size": "16px", "slug": "sm", "name": "Small" },
        { "size": "24px", "slug": "md", "name": "Medium" },
        { "size": "32px", "slug": "lg", "name": "Large" },
        { "size": "48px", "slug": "xl", "name": "Extra Large" },
        { "size": "80px", "slug": "2xl", "name": "2X Large" },
        { "size": "100px", "slug": "3xl", "name": "3X Large" }
      ]
    }
  },
  "styles": {
    "color": {
      "background": "#ffffff",
      "text": "#222222"
    },
    "typography": {
      "fontFamily": "var(--wp--preset--font-family--roboto)",
      "fontSize": "16px",
      "lineHeight": 1.6
    },
    "elements": {
      "heading": {
        "typography": {
          "lineHeight": 1.3,
          "fontWeight": "700"
        }
      },
      "link": {
        "color": { "text": "#e94560" },
        ":hover": { "color": { "text": "#ff6b35" } }
      }
    }
  },
  "templateParts": [
    { "name": "header", "title": "Header", "area": "header" },
    { "name": "footer", "title": "Footer", "area": "footer" }
  ]
}
