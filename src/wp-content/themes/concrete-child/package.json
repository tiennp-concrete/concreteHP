{
  "name": "concrete-child-blocks",
  "version": "0.1.0",
  "private": true,
  "description": "Custom Gutenberg blocks for Concrete HP child theme",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "wp-scripts build --blocks-manifest --webpack-src-dir=blocks/src --output-path=blocks/build",
    "start": "wp-scripts start --blocks-manifest --webpack-src-dir=blocks/src --output-path=blocks/build"
  },
  "devDependencies": {
    "@wordpress/icons": "^12.2.0",
    "@wordpress/scripts": "^32.0.0"
  },
  "dependencies": {
    "swiper": "^12.1.3"
  }
}
