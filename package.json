{
  "name": "concrete-hp",
  "version": "1.0.0",
  "description": "Concrete HP - WordPress Theme with SCSS",
  "main": "gulpfile.js",
  "scripts": {
    "start": "gulp",
    "build": "gulp sass",
    "watch": "gulp watch",
    "build:blocks": "node wordpress/wp-content/themes/concrete-child/scripts/html-to-blocks.js",
    "build:blocks:builddir": "node wordpress/wp-content/themes/concrete-child/scripts/html-to-blocks.js --out-dir build",
    "build:parts": "node wordpress/wp-content/themes/concrete-child/scripts/html-to-blocks.js --only parts",
    "watch:blocks": "node wordpress/wp-content/themes/concrete-child/scripts/watch-blocks.js",
    "watch:blocks:builddir": "BLOCKS_OUT_DIR=build node wordpress/wp-content/themes/concrete-child/scripts/watch-blocks.js",
    "watch:parts": "node wordpress/wp-content/themes/concrete-child/scripts/watch-blocks.js --parts-only",
    "watch:parts:builddir": "BLOCKS_OUT_DIR=build WATCH_PARTS_ONLY=1 node wordpress/wp-content/themes/concrete-child/scripts/watch-blocks.js",
    "build:scss": "cd wordpress/wp-content/themes/concrete-child && sass assets/scss/main.scss assets/css/main.css --style expanded",
    "watch:scss": "cd wordpress/wp-content/themes/concrete-child && sass assets/scss/main.scss assets/css/main.css --style expanded --watch",
    "build:theme": "npm run build:blocks && npm run build:scss"
  },
  "author": "ConcreteHP",
  "license": "GPL-2.0-or-later",
  "devDependencies": {
    "gulp": "^4.0.2",
    "gulp-autoprefixer": "^7.0.1",
    "gulp-clean-css": "^4.3.0",
    "gulp-notify": "^3.2.0",
    "gulp-plumber": "^1.2.1",
    "gulp-sass": "^5.1.0",
    "gulp-sourcemaps": "^3.0.0",
    "node-env-file": "^0.1.8",
    "sass": "^1.62.1"
  }
}
