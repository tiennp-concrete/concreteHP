{
  "$schema": "https://schemas.wp.org/wp/6.5/block.json",
  "apiVersion": 3,
  "name": "sunstar-showcase/hero",
  "title": "Sunstar Hero Section",
  "category": "common",
  "icon": "star",
  "description": "A hero banner section with title, subtitle, and call-to-action buttons",
  "supports": {
    "html": false,
    "align": true,
    "color": {
      "background": true,
      "text": true
    },
    "spacing": {
      "padding": true,
      "margin": true
    }
  },
  "attributes": {
    "title": {
      "type": "string",
      "default": "Welcome to Our Awesome Studio"
    },
    "subtitle": {
      "type": "string",
      "default": "Create digital experiences that matter"
    },
    "backgroundColor": {
      "type": "string",
      "default": "#001f3f"
    },
    "textColor": {
      "type": "string",
      "default": "#ffffff"
    },
    "backgroundImage": {
      "type": "string",
      "default": ""
    },
    "buttonLabel": {
      "type": "string",
      "default": "Get Started"
    },
    "buttonLink": {
      "type": "string",
      "default": "#"
    }
  },
  "textdomain": "sunstar-showcase-block",
  "editorScript": "file:./index.js",
  "editorStyle": "file:./style-editor.css",
  "style": "file:./style.css"
}
