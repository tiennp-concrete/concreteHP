# Your Project Name here : docker run container as this name
PROJECT_NAME=concrete-hp

# Your repository Name here
REPOSITORY=""

# Your Project WordPress theme Name here
THEME_NAME="concrete-child"

# This is local port number for web container
PORT_NUM=8825

# Database Configuration
WORDPRESS_DB_NAME=wordpress
WORDPRESS_DB_USER=wordpress
WORDPRESS_DB_PASSWORD=wordpress
WORDPRESS_TABLE_PREFIX=wp_
WORDPRESS_DEBUG=1

# MariaDB Configuration
MARIADB_ROOT_PASSWORD=somewordpress

# phpMyAdmin port
PHPMYADMIN_PORT=8081

# Further Options: SSL Settings
# DOMAINS=domain.com,www.domain.com
# LETSENCRYPT_EMAIL="startup@example.com"
